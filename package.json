{
  "name": "resenha-local",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "prebuild": "expo prebuild --clean",
    "build:dev": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production --platform android",
    "clear": "rm -rf android .expo",
    "build:android": "npx expo prebuild --platform android",
    "apk": "cd android && ./gradlew assembleRelease",
    "stop": "cd android && ./gradlew --stop",
    "android:install": "cd android/app/build/outputs/apk/release && adb install app-release.apk",
    "android:uninstall": "adb uninstall com.resenhalocal.app",
    "submit:production": "eas submit --profile production --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@op-engineering/op-sqlite": "^7.0.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "expo": "~51.0.0",
    "expo-dev-client": "~4.0.0",
    "expo-file-system": "~17.0.1",
    "expo-local-authentication": "~14.0.1",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.0",
    "nearby-transport": "file:./modules/nearby-transport",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-get-random-values": "^1.11.0",
    "react-native-libsodium": "^1.1.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.0",
    "root-detection": "file:./modules/root-detection",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.0.0",
    "typescript": "~5.3.0"
  }
}
